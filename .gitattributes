# --- Normalización de fin de línea ---
* text=auto eol=lf

# Mantener CRLF en scripts de Windows
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# --- Código fuente ---
*.java   text diff=java
*.js     text diff=javascript
*.jsx    text diff=javascript
*.ts     text diff=typescript
*.tsx    text diff=typescript
*.css    text
*.html   text
*.xml    text
*.yml    text
*.yaml   text
*.json   text
*.sql    text diff=sql

# --- Next.js / React específicos ---
next-env.d.ts text
*.tsbuildinfo text

# --- Documentación ---
*.md    text
*.txt   text
*.adoc  text

# --- Archivos binarios (no diff) ---
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.jar   binary
*.exe   binary

# --- Maven wrapper ---
/mvnw     text eol=lf
/mvnw.cmd text eol=crlf

# --- Docker ---
Dockerfile text
*.dockerignore text

# --- Configuración IDE ---
*.iml   text
.idea/** text
.vscode/** text

